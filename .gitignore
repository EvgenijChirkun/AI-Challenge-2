checkpoints/
saved_models/
model_outputs/
outputs/
runs/
wandb/
mlruns/
lightning_logs/

# ─────────────────────────────────────────────────────────────
# Data files (large raw datasets — reference them instead)
# ─────────────────────────────────────────────────────────────
*.csv.gz
*.parquet
*.arrow
*.feather
*.db
*.sqlite
*.sqlite3

# ─────────────────────────────────────────────────────────────
# Task artifacts — NOT ignored by default
# (Artifacts committed intentionally should be inside task-N/artifacts/)
# ─────────────────────────────────────────────────────────────
# task-*/artifacts/ is intentionally NOT listed here so that
# submitted artifacts are tracked by git.
