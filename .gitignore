# ─────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
pip-wheel-metadata/
.venv/
venv/
ENV/
env/
.env/
env.bak/
venv.bak/
virtualenv/
.virtualenv/
site-packages/

# Jupyter Notebooks
.ipynb_checkpoints/
*.ipynb_checkpoints

# PyTest
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/

# mypy / pyright / ruff
.mypy_cache/
.dmypy.json
dmypy.json
.pyright/
.ruff_cache/

# ─────────────────────────────────────────────────────────────
# Node.js / JavaScript / TypeScript
# ─────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
.yarn/
package-lock.json
yarn.lock
pnpm-lock.yaml
.npm/
.eslintcache
.stylelintcache
dist/
out/
.next/
.nuxt/
.output/
.cache/
.parcel-cache/
.turbo/
.svelte-kit/
storybook-static/

# ─────────────────────────────────────────────────────────────
# Java / Kotlin
# ─────────────────────────────────────────────────────────────
*.class
*.jar
*.war
*.ear
*.nar
target/
hs_err_pid*

# Gradle
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
!**/src/main/**/build/
!**/src/test/**/build/

# Maven
!.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# ─────────────────────────────────────────────────────────────
# Go
# ─────────────────────────────────────────────────────────────
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
/vendor/
/go/bin/

# ─────────────────────────────────────────────────────────────
# Rust
# ─────────────────────────────────────────────────────────────
target/
Cargo.lock
**/*.rs.bk

# ─────────────────────────────────────────────────────────────
